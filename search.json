---
layout: none
---
{% assign translation_lookup = site.data.post_translations %}
[
  {% for post in site.posts %}
  {% assign post_translation_key = post.translation_key | default: translation_lookup[post.url] %}
  {
    "title": {{ post.title | jsonify }},
    "url": "{{ post.url | prepend: site.baseurl }}",
    "date": "{{ post.date | date: '%Y-%m-%d' }}",
    "tags": {{ post.tags | jsonify }},
    "lang": {{ post.lang | default: "en" | jsonify }},
    "translation_key": {{ post_translation_key | jsonify }},
    "content": {{ post.content | strip_html | truncatewords: 80 | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
